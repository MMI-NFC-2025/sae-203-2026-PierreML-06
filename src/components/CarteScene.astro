---
import { Image } from 'astro:assets';
import PbImage from './PbImage.astro';
import starEmpty from '../assets/icons/favorite.svg';
import starFilled from '../assets/icons/favorite_filled.svg';

interface Props {
  scene: any;
}

const { scene } = Astro.props;
---

<article class="group relative bg-white rounded-2xl overflow-hidden hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md border-t-2 border-or">
  <button
    class="fav-btn absolute top-3 right-3 z-10 w-8 h-8 flex items-center justify-center bg-marron/40 backdrop-blur-sm rounded-full hover:bg-marron/60 transition-colors cursor-pointer border-none"
    data-type="scene"
    data-id={scene.id}
    aria-label="Ajouter aux favoris"
    style="display:none">
    <Image src={starEmpty} alt="" width={16} height={16} class="star-empty w-4 h-4" />
    <Image src={starFilled} alt="" width={16} height={16} class="star-filled hidden w-4 h-4" />
  </button>
  <a href={`/scenes/${scene.id}`} class="block">
    <div class="relative w-full h-64 overflow-hidden">
      <PbImage
        record={scene}
        recordImage={scene.photo}
        alt={scene.nom}
        class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-500"
        width={600}
        height={256}
      />
      <div class="absolute inset-0 bg-linear-to-t from-marron/50 to-transparent"></div>
    </div>
    <div class="p-6">
      <h2 class="font-titre text-lg font-bold text-marron uppercase mb-2 leading-tight">{scene.nom}</h2>
      {scene.description && (
        <p class="text-marron/60 text-sm font-corps leading-relaxed line-clamp-3 mb-3">{scene.description}</p>
      )}
      {scene.capacite && (
        <p class="text-or text-xs font-corps font-semibold uppercase tracking-wide flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-or inline-block"></span>
          {scene.capacite} places
        </p>
      )}
    </div>
  </a>
</article>
