---
import { Image } from 'astro:assets';
import facebookUrl from '../assets/icons/facebook.svg';
import instagramUrl from '../assets/icons/instagram.svg';
import xUrl from '../assets/icons/X.svg';
import youtubeUrl from '../assets/icons/youtube.svg';
---

<footer class="bg-marron text-beige-claire py-16 px-8">
  <div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

    <div>
      <p class="font-titre text-2xl font-bold text-beige-claire uppercase tracking-widest">FESTICLOSE</p>
    </div>

    <nav aria-label="Liens utiles du pied de page">
      <h3 class="font-corps text-or text-sm uppercase tracking-widest mb-4 font-semibold">Menu</h3>
      <ul class="list-none p-0 m-0 flex flex-col gap-2">
        <li><a href="/festival" class="text-beige-claire/80 hover:text-or transition-colors text-sm">Le festival</a></li>
        <li><a href="/programmation" class="text-beige-claire/80 hover:text-or transition-colors text-sm">La programmation</a></li>
        <li><a href="/artistes" class="text-beige-claire/80 hover:text-or transition-colors text-sm">Nos artistes</a></li>
        <li><a href="/scenes" class="text-beige-claire/80 hover:text-or transition-colors text-sm">Nos scènes</a></li>
        <li><a href="/infos_partique" class="text-beige-claire/80 hover:text-or transition-colors text-sm">Infos pratiques</a></li>
        <li><a href="/contact" class="text-beige-claire/80 hover:text-or transition-colors text-sm">Contact</a></li>
      </ul>
    </nav>

    <div>
      <h3 class="font-corps text-or text-sm uppercase tracking-widest mb-4 font-semibold">Contact</h3>
      <address class="not-italic text-beige-claire/80 text-sm leading-relaxed">
        festiclose@gmail.com<br />
        09.54.21.67.21<br />
        Temple Saint-Martin de Montbéliard<br />
        25200
      </address>
    </div>

    <div>
      <h3 class="font-corps text-or text-sm uppercase tracking-widest mb-4 font-semibold">Nous suivre</h3>
      <div class="flex gap-4 mb-6">
        <a href="https://www.facebook.com/?locale=fr_FR" target="_blank" rel="noopener noreferrer" aria-label="Suivez-nous sur Facebook">
          <Image src={facebookUrl} alt="" aria-hidden="true" width={28} height={28} class="w-7 h-7 opacity-80 hover:opacity-100 transition-opacity" />
        </a>
        <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" aria-label="Suivez-nous sur Instagram">
          <Image src={instagramUrl} alt="" aria-hidden="true" width={28} height={28} class="w-7 h-7 opacity-80 hover:opacity-100 transition-opacity" />
        </a>
        <a href="https://x.com/" target="_blank" rel="noopener noreferrer" aria-label="Suivez-nous sur Twitter/X">
          <Image src={xUrl} alt="" aria-hidden="true" width={28} height={28} class="w-7 h-7 opacity-80 hover:opacity-100 transition-opacity" />
        </a>
        <a href="https://www.youtube.com/" target="_blank" rel="noopener noreferrer" aria-label="Suivez-nous sur YouTube">
          <Image src={youtubeUrl} alt="" aria-hidden="true" width={28} height={28} class="w-7 h-7 opacity-80 hover:opacity-100 transition-opacity" />
        </a>
      </div>
      <div class="flex flex-col gap-2">
        <a href="/mentions-legales" class="text-beige-claire/80 hover:text-or transition-colors text-sm">Mentions légales</a>
        <a href="/confidentialite" class="text-beige-claire/80 hover:text-or transition-colors text-sm">Politique de confidentialité</a>
      </div>
    </div>

  </div>
</footer>

<button
  id="btn-retour-haut"
  aria-label="Retour en haut de page"
  class="hidden fixed bottom-6 right-6 w-12 h-12 bg-rouge rounded-full flex items-center justify-center shadow-lg z-50 cursor-pointer hover:-translate-y-1 transition-transform">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
    <polyline points="18 15 12 9 6 15"></polyline>
  </svg>
</button>

<script>
  import '../js/scrollTop.js';
</script>
