---
import { Image } from 'astro:assets';
import logoUrl from '../assets/icons/logo.svg';
import userUrl from '../assets/icons/user.svg';

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 w-full h-[70px] px-6 flex justify-between items-center z-[100] bg-beige-claire shadow-sm">
  <a href="/" class="z-[110] shrink-0">
    <Image src={logoUrl} alt="Logo Festiclose - Retour a l'accueil" width={98} height={18} style="width:98px;height:18px" />
  </a>

  <nav id="nav-desktop" class="hidden md:flex items-center gap-7">
    <a href="/" class={`font-corps text-[11px] font-bold uppercase tracking-widest hover:text-or transition-colors ${currentPath === '/' ? 'text-or' : 'text-marron'}`}>Accueil</a>
    <a href="/festival" class={`font-corps text-[11px] font-bold uppercase tracking-widest hover:text-or transition-colors ${currentPath === '/festival' ? 'text-or' : 'text-marron'}`}>Le Festival</a>
    <a href="/programmation" class={`font-corps text-[11px] font-bold uppercase tracking-widest hover:text-or transition-colors ${currentPath === '/programmation' ? 'text-or' : 'text-marron'}`}>La Programmation</a>
    <a href="/artistes" class={`font-corps text-[11px] font-bold uppercase tracking-widest hover:text-or transition-colors ${currentPath.startsWith('/artistes') ? 'text-or' : 'text-marron'}`}>Nos Artistes</a>
    <a href="/scenes" class={`font-corps text-[11px] font-bold uppercase tracking-widest hover:text-or transition-colors ${currentPath.startsWith('/scenes') ? 'text-or' : 'text-marron'}`}>Nos Scenes</a>
    <a href="/infos_partique" class={`font-corps text-[11px] font-bold uppercase tracking-widest hover:text-or transition-colors ${currentPath === '/infos_partique' ? 'text-or' : 'text-marron'}`}>Infos Pratiques</a>
    <a href="/contact" class={`font-corps text-[11px] font-bold uppercase tracking-widest hover:text-or transition-colors ${currentPath === '/contact' ? 'text-or' : 'text-marron'}`}>Contact</a>
    <a
      id="user-btn-desktop"
      href="/profil"
      aria-label="Mon compte"
      class="ml-2 w-9 h-9 rounded-full border border-beige hover:border-or transition-colors flex items-center justify-center shrink-0 overflow-hidden"
    >
      <Image id="user-icon-desktop" src={userUrl} alt="" aria-hidden="true" width={20} height={20} class="w-5 h-5 transition-all" />
    </a>
  </nav>

  <div class="md:hidden flex items-center gap-3">
    <a
      id="user-btn-mobile"
      href="/profil"
      aria-label="Mon compte"
      class="w-9 h-9 rounded-full border border-beige hover:border-or transition-colors flex items-center justify-center shrink-0 overflow-hidden"
    >
      <Image id="user-icon-mobile" src={userUrl} alt="" aria-hidden="true" width={20} height={20} class="w-5 h-5 transition-all" />
    </a>

    <button
      id="menu-btn"
      aria-label="Ouvrir le menu de navigation"
      aria-expanded="false"
      aria-controls="nav-principale"
      class="flex flex-col gap-1.25 z-110 relative cursor-pointer bg-transparent border-none p-2"
    >
      <span id="barre1" class="block w-6 h-[2px] bg-marron transition-all duration-300 origin-center"></span>
      <span id="barre2" class="block w-6 h-[2px] bg-marron transition-all duration-300"></span>
      <span id="barre3" class="block w-6 h-[2px] bg-marron transition-all duration-300 origin-center"></span>
    </button>
  </div>
</header>

<nav
  id="nav-principale"
  class="fixed inset-0 bg-marron hidden flex-col justify-center z-99 px-10 md:hidden"
  aria-hidden="true"
>
  <button
    id="menu-close"
    aria-label="Fermer le menu"
    class="absolute top-5 right-5 text-beige/60 hover:text-beige-claire transition-colors cursor-pointer bg-transparent border-none p-2"
  >
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="4" y1="4" x2="24" y2="24" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
      <line x1="24" y1="4" x2="4" y2="24" stroke="currentColor" stroke-width="3" stroke-linecap="round"></line>
    </svg>
  </button>

  <ul id="nav-mobile-list" class="flex flex-col gap-5 list-none p-0 m-0">
    <li><a href="/" class={`font-corps font-bold text-base uppercase tracking-wide hover:text-or transition-colors ${currentPath === '/' ? 'text-or' : 'text-white'}`}>Accueil</a></li>
    <li><a href="/festival" class={`font-corps font-bold text-base uppercase tracking-wide hover:text-or transition-colors ${currentPath === '/festival' ? 'text-or' : 'text-white'}`}>Le Festival</a></li>
    <li><a href="/programmation" class={`font-corps font-bold text-base uppercase tracking-wide hover:text-or transition-colors ${currentPath === '/programmation' ? 'text-or' : 'text-white'}`}>La Programmation</a></li>
    <li><a href="/artistes" class={`font-corps font-bold text-base uppercase tracking-wide hover:text-or transition-colors ${currentPath.startsWith('/artistes') ? 'text-or' : 'text-white'}`}>Nos Artistes</a></li>
    <li><a href="/scenes" class={`font-corps font-bold text-base uppercase tracking-wide hover:text-or transition-colors ${currentPath.startsWith('/scenes') ? 'text-or' : 'text-white'}`}>Nos Scenes</a></li>
    <li><a href="/infos_partique" class={`font-corps font-bold text-base uppercase tracking-wide hover:text-or transition-colors ${currentPath === '/infos_partique' ? 'text-or' : 'text-white'}`}>Infos Pratiques</a></li>
    <li><a href="/contact" class={`font-corps font-bold text-base uppercase tracking-wide hover:text-or transition-colors ${currentPath === '/contact' ? 'text-or' : 'text-white'}`}>Contact</a></li>
  </ul>
</nav>

<script>
  import '../js/menu.js';
  import '../js/headerUser.js';
</script>

