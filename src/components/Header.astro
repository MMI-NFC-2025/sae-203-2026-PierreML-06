---
import logoUrl from '../assets/icons/logo.svg?url';
import userUrl from '../assets/icons/user.svg?url';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Accueil', active: currentPath === '/' },
  { href: '/festival', label: 'Le Festival', active: currentPath === '/festival' },
  { href: '/programmation', label: 'La Programmation', active: currentPath === '/programmation' },
  { href: '/artistes', label: 'Nos Artistes', active: currentPath.startsWith('/artistes') },
  { href: '/scenes', label: 'Nos Scènes', active: currentPath.startsWith('/scenes') },
  { href: '/infos_partique', label: 'Infos Pratiques', active: currentPath === '/infos_partique' },
  { href: '/contact', label: 'Contact', active: currentPath === '/contact' },
];
---

<!-- HEADER -->
<header class="fixed top-0 left-0 w-full h-[70px] px-6 flex justify-between items-center z-[100] bg-beige-claire shadow-sm">
  <a href="/" class="z-[110] shrink-0">
    <img src={logoUrl} alt="Logo Festicloze — Retour à l'accueil" width="98" height="18" style="width:98px;height:18px" />
  </a>

  <!-- Nav desktop -->
  <nav id="nav-desktop" class="hidden md:flex items-center gap-7">
    {navLinks.map(link => (
      <a
        href={link.href}
        class={`font-corps text-[11px] font-bold uppercase tracking-widest hover:text-or transition-colors ${link.active ? 'text-or' : 'text-marron'}`}>
        {link.label}
      </a>
    ))}
    <a
      id="user-btn-desktop"
      href="/profil"
      aria-label="Mon compte"
      class="ml-2 w-9 h-9 rounded-full border border-beige hover:border-or transition-colors flex items-center justify-center shrink-0 overflow-hidden">
      <img id="user-icon-desktop" src={userUrl} alt="" aria-hidden="true" class="w-5 h-5 transition-all" />
    </a>
  </nav>

  <!-- Bouton user mobile -->
  <div class="md:hidden flex items-center gap-3">
    <a
      id="user-btn-mobile"
      href="/profil"
      aria-label="Mon compte"
      class="w-9 h-9 rounded-full border border-beige hover:border-or transition-colors flex items-center justify-center shrink-0 overflow-hidden">
      <img id="user-icon-mobile" src={userUrl} alt="" aria-hidden="true" class="w-5 h-5 transition-all" />
    </a>

  <!-- Hamburger mobile -->
  <button
    id="menu-btn"
    aria-label="Ouvrir le menu de navigation"
    aria-expanded="false"
    aria-controls="nav-principale"
    class="flex flex-col gap-1.25 z-110 relative cursor-pointer bg-transparent border-none p-2">
    <span id="barre1" class="block w-6 h-[2px] bg-marron transition-all duration-300 origin-center"></span>
    <span id="barre2" class="block w-6 h-[2px] bg-marron transition-all duration-300"></span>
    <span id="barre3" class="block w-6 h-[2px] bg-marron transition-all duration-300 origin-center"></span>
  </button>
  </div>
</header>

<!-- NAV OVERLAY (mobile uniquement) -->
<nav
  id="nav-principale"
  class="fixed inset-0 bg-marron hidden flex-col justify-center z-99 px-10 md:hidden"
  aria-hidden="true">

  <!-- Bouton fermeture X -->
  <button
    id="menu-close"
    aria-label="Fermer le menu"
    class="absolute top-5 right-5 text-beige/60 hover:text-beige-claire transition-colors cursor-pointer bg-transparent border-none p-2">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="4" y1="4" x2="24" y2="24" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      <line x1="24" y1="4" x2="4" y2="24" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
    </svg>
  </button>

  <ul id="nav-mobile-list" class="flex flex-col gap-5 list-none p-0 m-0">
    {navLinks.map(link => (
      <li>
        <a
          href={link.href}
          class={`font-corps font-bold text-base uppercase tracking-wide hover:text-or transition-colors ${link.active ? 'text-or' : 'text-white'}`}>
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  import '../js/menu.js';
  import pb, { getImageUrl } from '../js/backend.mjs';

  function applyAvatar(imgEl: HTMLImageElement, user: Record<string, any>) {
    if (user['img']) {
      const url = getImageUrl(user, user['img']);
      if (url) {
        imgEl.src = url;
        imgEl.alt = user['name'] || 'Mon profil';
        imgEl.removeAttribute('aria-hidden');
        imgEl.className = 'w-full h-full object-cover';
        return;
      }
    }
    // Pas de photo : initiale dans un span, on cache l'img
    imgEl.style.display = 'none';
    const parent = imgEl.parentElement;
    if (parent && !parent.querySelector('.user-initiale')) {
      const span = document.createElement('span');
      span.className = 'user-initiale font-corps font-bold text-marron text-sm';
      const nom = user['name'] || user['email'] || '';
      span.textContent = nom.charAt(0).toUpperCase();
      parent.appendChild(span);
    }
  }

  if (pb.authStore.isValid && pb.authStore.record) {
    const user = pb.authStore.record as Record<string, any>;
    const desktop = document.getElementById('user-icon-desktop') as HTMLImageElement | null;
    const mobile = document.getElementById('user-icon-mobile') as HTMLImageElement | null;
    if (desktop) applyAvatar(desktop, user);
    if (mobile) applyAvatar(mobile, user);

    // Lien Admin uniquement pour les admins
    if (user['admin']) {
      const isAdmin = window.location.pathname === '/admin';
      const clsDesktop = `font-corps text-[11px] font-bold uppercase tracking-widest hover:text-or transition-colors ${isAdmin ? 'text-or' : 'text-marron'}`;
      const clsMobile = `font-corps font-bold text-base uppercase tracking-wide hover:text-or transition-colors ${isAdmin ? 'text-or' : 'text-white'}`;

      const navDesktop = document.getElementById('nav-desktop');
      if (navDesktop) {
        const a = document.createElement('a');
        a.href = '/admin';
        a.className = clsDesktop;
        a.textContent = 'Admin';
        navDesktop.insertBefore(a, navDesktop.lastElementChild);
      }

      const navMobile = document.getElementById('nav-mobile-list');
      if (navMobile) {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = '/admin';
        a.className = clsMobile;
        a.textContent = 'Admin';
        li.appendChild(a);
        navMobile.appendChild(li);
      }
    }
  }
</script>
