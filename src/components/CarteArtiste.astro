---
import PbImage from './PbImage.astro';

interface Props {
  artiste: any;
  date?: string | null;
  scene_nom?: string | null;
}

const { artiste, date, scene_nom } = Astro.props;
---

<article class="group bg-white rounded-2xl overflow-hidden hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md border-t-2 border-or">
  <a href={`/artistes/${artiste.id}`} class="block h-full">
    <div class="relative w-full h-52 overflow-hidden">
      <PbImage
        record={artiste}
        recordImage={artiste.photo_principale}
        alt={artiste.nom}
        class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-500"
        width={400}
        height={208}
      />
      <div class="absolute inset-0 bg-linear-to-t from-marron/50 to-transparent"></div>
    </div>
    <div class="p-5">
      <h2 class="font-titre text-sm font-bold text-marron uppercase mb-1 leading-snug">{artiste.nom}</h2>
      {artiste.genre_musical && (
        <span class="inline-block px-3 py-0.5 bg-beige text-or text-xs font-corps font-semibold uppercase tracking-wider rounded-full mb-2">
          {artiste.genre_musical}
        </span>
      )}
      {(date || scene_nom) && (
        <p class="text-marron/50 text-xs font-corps leading-relaxed mt-2">
          {date && <time class="block">{date}</time>}
          {scene_nom && <span class="block">{scene_nom}</span>}
        </p>
      )}
    </div>
  </a>
</article>
