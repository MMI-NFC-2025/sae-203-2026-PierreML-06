---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroBannerImg from '../assets/img/hero_festival.avif';
import saintMartinImg from '../assets/img/saint_martin.avif';
---

<Layout title="Le Festival — Festicloze">
  <main class="pt-17.5">

    <!-- BANNIÈRE -->
    <section class="relative h-[50vh] min-h-75 md:h-[60vh] flex items-end overflow-hidden">
      <Image
        src={heroBannerImg}
        alt="Peinture baroque représentant des musiciens"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 px-8 md:px-16 pb-10 md:pb-16 w-full max-w-6xl mx-auto">
        <h1 class="font-titre text-[32px] md:text-[48px] font-normal leading-none tracking-[2.56px]" style="color:#ffffff">LE FESTIVAL</h1>
      </div>
    </section>

    <!-- L'ESPRIT + IMAGE (desktop : 2 colonnes) -->
    <div class="max-w-6xl mx-auto px-8 md:px-16 py-12 md:py-20 md:grid md:grid-cols-2 md:gap-16 md:items-center">

      <section>
        <h2 class="font-corps font-bold text-marron text-base tracking-wide mb-4">L'Esprit Festicloze</h2>
        <p class="text-marron/80 text-sm leading-relaxed">
          Né au majestueux Temple Saint-Martin, Festicloze célèbre l'opéra baroque au cœur des Lumières de Montbéliard.
          Concerts, danses et rencontres s'unissent pour offrir une expérience unique, mêlant excellence musicale,
          patrimoine historique et magie de Noël.
        </p>
      </section>

      <div class="mt-10 md:mt-0">
        <Image
          src={saintMartinImg}
          alt="Vue intérieure du Temple Saint-Martin illuminé lors d'un concert baroque"
          class="w-full object-cover max-h-52 md:max-h-80 md:rounded-2xl"
        />
      </div>
    </div>

    <!-- ÉQUIPE -->
    <section class="max-w-6xl mx-auto px-8 md:px-16 pb-12">
      <h2 class="font-corps font-bold text-marron text-base tracking-wide mb-4">Équipe</h2>
      <div class="md:grid md:grid-cols-2 md:gap-16 md:items-start">
        <p class="text-marron/80 text-sm leading-relaxed mb-4 md:mb-0">
          Orchestré par une équipe passionnée, Festicloze s'appuie sur une régie technique d'experts.
          De la direction artistique à la mise en lumière, tous s'unissent en coulisses pour garantir
          une qualité de spectacle irréprochable.
        </p>
        <ul class="list-disc pl-5 flex flex-col gap-2 text-marron/80 text-sm">
          <li>Sarah Monteverdi (Directrice Artistique)</li>
          <li>L'Atelier des Lumières (Scénographie)</li>
        </ul>
      </div>
    </section>

    <!-- VALEURS, THÉMATIQUE, ENGAGEMENTS -->
    <section class="max-w-6xl mx-auto px-8 md:px-16 pb-16 flex flex-col md:flex-row md:gap-12 gap-4">
      <p class="text-marron text-sm leading-relaxed tracking-wide md:flex-1">
        <strong>Valeurs</strong> : Respect du patrimoine et transmission du baroque à tous les publics.
      </p>
      <p class="text-marron text-sm leading-relaxed tracking-wide md:flex-1">
        <strong>Thématique 2025</strong> : La magie de Noël sublime les artistes dans une ambiance chaleureuse.
      </p>
      <p class="text-marron text-sm leading-relaxed tracking-wide md:flex-1">
        <strong>Engagements</strong> : Un événement éco-responsable, inclusif et ancré dans le territoire local.
      </p>
    </section>

  </main>
</Layout>
