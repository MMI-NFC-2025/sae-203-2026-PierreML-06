---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import PbImage from '../components/PbImage.astro';
import theatreImg from '../assets/img/theatre.avif';
import { getArtistesByDate } from '../../backend/backend.mjs';

let artistes: any[] = [];
try {
  artistes = await getArtistesByDate();
} catch (_) {}

const genres = [...new Set(artistes.map((a: any) => a.genre_musical).filter(Boolean))].sort() as string[];

const scenesMap = new Map<string, string>();
for (const artiste of artistes) {
  const sceneId = (artiste.scene as string) ?? artiste.expand?.scene?.id ?? '';
  const sceneNom = artiste.expand?.scene?.nom ?? '';
  if (sceneId && sceneNom && !scenesMap.has(sceneId)) {
    scenesMap.set(sceneId, sceneNom);
  }
}
const scenes = Array.from(scenesMap, ([id, nom]) => ({ id, nom })).sort((a, b) => a.nom.localeCompare(b.nom, 'fr'));

const joursMap = new Map<string, { label: string; iso: string; artistes: any[] }>();
for (const artiste of artistes) {
  if (!artiste.dates_de_representation) continue;
  const dt = new Date(artiste.dates_de_representation);
  const iso = dt.toISOString().substring(0, 10);
  if (!joursMap.has(iso)) {
    joursMap.set(iso, {
      iso,
      label: dt.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' }).toUpperCase(),
      artistes: [],
    });
  }
  joursMap.get(iso)!.artistes.push(artiste);
}
const jours = Array.from(joursMap.values()).sort((a, b) => a.iso.localeCompare(b.iso));
---

<Layout title="La Programmation - Festicloze">
  <main class="pt-17.5">
    <section class="max-w-5xl mx-auto px-6 py-12">
      <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-3">Programme 2025</p>
      <h1 class="font-titre text-4xl md:text-5xl text-marron leading-none mb-2">La Programmation</h1>
      <div class="h-px w-12 bg-or mb-10"></div>
      <Image
        src={theatreImg}
        alt="Interieur du theatre avec ses balcons"
        class="w-full rounded-2xl object-cover max-h-105 mb-3"
      />
      <p class="text-center text-marron/40 text-xs font-corps mb-12 italic">Temple Saint-Martin de Montbeliard</p>

      {jours.length === 0 && (
        <p class="text-center text-marron/40 font-corps text-sm py-10">Programme a venir.</p>
      )}

      {jours.length > 0 && (
        <>
          <div class="mb-10 flex flex-col gap-4">
            <div class="flex items-center gap-3">
              <div class="relative flex-1">
                <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-marron/40 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="11" cy="11" r="8" />
                  <path d="m21 21-4.35-4.35" />
                </svg>
                <input
                  id="recherche-programmation"
                  type="text"
                  placeholder="Rechercher un artiste..."
                  class="w-full bg-beige rounded-xl pl-10 pr-4 py-2.5 text-marron text-sm border-b-2 border-transparent focus:border-or outline-none transition-colors font-corps"
                />
              </div>
              <button data-sort="date" class="filtre-sort shrink-0 px-4 py-2.5 rounded-xl text-xs font-corps font-bold uppercase tracking-wide border cursor-pointer transition-colors bg-marron text-beige-claire border-marron">Date</button>
              <button data-sort="alpha" class="filtre-sort shrink-0 px-4 py-2.5 rounded-xl text-xs font-corps font-bold uppercase tracking-wide border cursor-pointer transition-colors bg-transparent text-marron border-beige hover:border-marron">A - Z</button>
            </div>

            <div class="flex flex-wrap items-center gap-3">
              {jours.length > 0 && (
                <div class="flex flex-col gap-1">
                  <label class="font-corps text-marron/40 text-xs uppercase tracking-widest">Jour</label>
                  <select id="filtre-jour" class="bg-beige rounded-xl px-4 py-2.5 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors font-corps cursor-pointer">
                    <option value="">Tous les jours</option>
                    {jours.map((jour) => (
                      <option value={jour.iso}>{jour.label}</option>
                    ))}
                  </select>
                </div>
              )}
              {genres.length > 0 && (
                <div class="flex flex-col gap-1">
                  <label class="font-corps text-marron/40 text-xs uppercase tracking-widest">Genre</label>
                  <select id="filtre-genre" class="bg-beige rounded-xl px-4 py-2.5 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors font-corps cursor-pointer">
                    <option value="">Tous les genres</option>
                    {genres.map((genre) => (
                      <option value={genre}>{genre}</option>
                    ))}
                  </select>
                </div>
              )}
              {scenes.length > 0 && (
                <div class="flex flex-col gap-1">
                  <label class="font-corps text-marron/40 text-xs uppercase tracking-widest">Scene</label>
                  <select id="filtre-scene" class="bg-beige rounded-xl px-4 py-2.5 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors font-corps cursor-pointer">
                    <option value="">Toutes les scenes</option>
                    {scenes.map((scene) => (
                      <option value={scene.id}>{scene.nom}</option>
                    ))}
                  </select>
                </div>
              )}
            </div>
          </div>

          <p id="aucun-resultat-programmation" class="text-center text-marron/60 py-10 hidden font-corps text-sm">Aucun artiste ne correspond a votre recherche.</p>

          <div id="liste-jours-programmation" class="flex flex-col gap-10">
            {jours.map((jour) => (
              <div data-jour-section={jour.iso}>
                <div class="flex items-center gap-4 mb-5">
                  <h2 class="font-titre text-2xl text-marron">{jour.label}</h2>
                  <div class="flex-1 h-px bg-beige"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4" data-jour-grid={jour.iso}>
                  {jour.artistes.map((artiste: any) => {
                    const heure = artiste.dates_de_representation
                      ? new Date(artiste.dates_de_representation).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })
                      : null;
                    const sceneNom = artiste.expand?.scene?.nom ?? null;
                    const jourIso = artiste.dates_de_representation
                      ? (artiste.dates_de_representation as string).substring(0, 10)
                      : '';
                    const genre = artiste.genre_musical ?? '';
                    const sceneId = (artiste.scene as string) ?? '';

                    return (
                      <a
                        href={`/artistes/${artiste.id}`}
                        data-nom={artiste.nom.toLowerCase()}
                        data-genre-label={genre.toLowerCase()}
                        data-date={artiste.dates_de_representation ?? ''}
                        data-jour={jourIso}
                        data-genre={genre}
                        data-scene={sceneId}
                        class="group bg-white border-t-2 border-or rounded-2xl shadow-sm overflow-hidden hover:-translate-y-0.5 transition-transform flex"
                      >
                        {artiste.photo_principale && (
                          <div class="w-24 shrink-0 overflow-hidden">
                            <PbImage
                              record={artiste}
                              recordImage={artiste.photo_principale}
                              alt={artiste.nom}
                              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                              width={96}
                              height={120}
                            />
                          </div>
                        )}
                        <div class="p-5 flex flex-col justify-between flex-1">
                          <div>
                            <p class="font-titre font-bold text-marron uppercase text-sm leading-tight group-hover:text-or transition-colors">{artiste.nom}</p>
                            {artiste.genre_musical && (
                              <p class="text-or text-xs font-corps font-semibold mt-1">{artiste.genre_musical}</p>
                            )}
                          </div>
                          <div class="flex items-center justify-between mt-3 pt-3 border-t border-beige">
                            {heure && <span class="font-corps text-marron font-bold text-sm">{heure}</span>}
                            {sceneNom && <span class="font-corps text-marron/40 text-xs">{sceneNom}</span>}
                          </div>
                        </div>
                      </a>
                    );
                  })}
                </div>
              </div>
            ))}
          </div>
        </>
      )}

      <div class="text-center mt-12">
        <a
          href="/Programation.pdf"
          download
          class="inline-block px-8 py-3 bg-marron text-beige-claire font-corps font-bold text-xs tracking-widest uppercase rounded-full hover:-translate-y-0.5 transition-transform"
        >
          Programme complet en PDF
        </a>
      </div>
    </section>

    <section class="bg-beige py-12 px-6">
      <div class="max-w-5xl mx-auto text-center">
        <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-3">Informations</p>
        <h2 class="font-titre text-2xl text-marron mb-4">Acces aux representations</h2>
        <div class="h-px w-12 bg-or mx-auto mb-6"></div>
        <p class="text-marron/70 font-corps text-sm leading-relaxed max-w-xl mx-auto">
          Toutes les representations ont lieu au Temple Saint-Martin, 25200 Montbeliard.
          Portes ouvertes 30 min avant le debut.
        </p>
      </div>
    </section>
  </main>
</Layout>

<script>
  const listeJours = document.getElementById('liste-jours-programmation');
  const aucunResultat = document.getElementById('aucun-resultat-programmation');

  if (listeJours) {
    const ACTIF = 'bg-marron text-beige-claire border-marron';
    const INACTIF_SORT = 'bg-transparent text-marron border-beige hover:border-marron';

    let activeJour = '';
    let activeGenre = '';
    let activeScene = '';
    let activeSort = 'date';
    let recherche = '';

    function cards() {
      return Array.from(listeJours.querySelectorAll('[data-nom]'));
    }

    function updateSections() {
      let visible = 0;

      Array.from(listeJours.querySelectorAll('[data-jour-section]')).forEach((section) => {
        const visibleCards = Array.from(section.querySelectorAll('[data-nom]')).filter((card) => {
          return card instanceof HTMLElement && card.style.display !== 'none';
        });

        if (section instanceof HTMLElement) {
          section.style.display = visibleCards.length > 0 ? '' : 'none';
        }

        visible += visibleCards.length;
      });

      if (aucunResultat instanceof HTMLElement) {
        aucunResultat.style.display = visible === 0 ? 'block' : 'none';
      }
    }

    function applyFilters() {
      cards().forEach((card) => {
        if (!(card instanceof HTMLElement)) return;

        const match =
          (!activeJour || card.dataset.jour === activeJour) &&
          (!activeGenre || card.dataset.genre === activeGenre) &&
          (!activeScene || card.dataset.scene === activeScene) &&
          (!recherche || (card.dataset.nom ?? '').includes(recherche) || (card.dataset.genreLabel ?? '').includes(recherche));

        card.style.display = match ? '' : 'none';
      });

      updateSections();
    }

    function applySort() {
      Array.from(listeJours.querySelectorAll('[data-jour-grid]')).forEach((grid) => {
        if (!(grid instanceof HTMLElement)) return;

        const sorted = Array.from(grid.children).filter((card) => card instanceof HTMLElement);
        sorted.sort((a, b) => {
          if (!(a instanceof HTMLElement) || !(b instanceof HTMLElement)) return 0;
          if (activeSort === 'alpha') {
            return (a.dataset.nom ?? '').localeCompare(b.dataset.nom ?? '', 'fr');
          }
          return (a.dataset.date ?? '').localeCompare(b.dataset.date ?? '');
        });

        sorted.forEach((card) => {
          grid.appendChild(card);
        });
      });
    }

    function updateSortBtns(sort) {
      document.querySelectorAll('[data-sort]').forEach((btn) => {
        if (!(btn instanceof HTMLElement)) return;
        const isActif = btn.dataset.sort === sort;
        btn.className = `filtre-sort shrink-0 px-4 py-2.5 rounded-xl text-xs font-corps font-bold uppercase tracking-wide border cursor-pointer transition-colors ${isActif ? ACTIF : INACTIF_SORT}`;
      });
    }

    document.getElementById('recherche-programmation')?.addEventListener('input', (e) => {
      if (!(e.target instanceof HTMLInputElement)) return;
      recherche = e.target.value.toLowerCase().trim();
      applyFilters();
    });

    document.getElementById('filtre-jour')?.addEventListener('change', (e) => {
      if (!(e.target instanceof HTMLSelectElement)) return;
      activeJour = e.target.value;
      applyFilters();
    });

    document.getElementById('filtre-genre')?.addEventListener('change', (e) => {
      if (!(e.target instanceof HTMLSelectElement)) return;
      activeGenre = e.target.value;
      applyFilters();
    });

    document.getElementById('filtre-scene')?.addEventListener('change', (e) => {
      if (!(e.target instanceof HTMLSelectElement)) return;
      activeScene = e.target.value;
      applyFilters();
    });

    document.querySelectorAll('[data-sort]').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (!(btn instanceof HTMLElement) || !btn.dataset.sort) return;
        activeSort = btn.dataset.sort;
        updateSortBtns(activeSort);
        applySort();
      });
    });
  }
</script>
