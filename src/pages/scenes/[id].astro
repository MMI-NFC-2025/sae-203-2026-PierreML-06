---
import Layout from '../../layouts/Layout.astro';
import PbImage from '../../components/PbImage.astro';
import pb from '../../js/backend.mjs';

const { id } = Astro.params;

let scene: any = null;
let artistes: any[] = [];
let notFound = false;

try {
  scene = await pb.collection('scenes').getOne(id as string);
} catch (e) {
  notFound = true;
}

if (notFound) {
  return Astro.redirect('/404');
}

try {
  artistes = await pb.collection('artistes').getFullList({
    filter: `scene = "${id}"`,
    sort: 'dates_de_representation',
  });
} catch (_) {}
---

<Layout title={`${scene.nom} — Festicloze`}>
  <main class="pt-17.5">
    <div class="max-w-4xl mx-auto px-6 py-12">

      <div class="mb-8">
        <a href="/scenes" class="inline-flex items-center gap-2 text-marron/50 hover:text-or text-xs font-corps font-bold uppercase tracking-widest transition-colors">
          &larr; Nos scènes
        </a>
      </div>

      <!-- PHOTO + INFOS -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start mb-12">

        <div class="w-full rounded-2xl overflow-hidden max-h-96 shadow-lg">
          <PbImage
            record={scene}
            recordImage={scene.photo}
            alt={scene.nom}
            class="w-full max-h-96 object-cover"
            width={600}
            height={384}
          />
        </div>

        <div class="flex flex-col gap-6">
          <div>
            <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-2">Lieu de représentation</p>
            <h1 class="font-titre text-[clamp(22px,4vw,36px)] font-bold text-marron leading-tight">{scene.nom}</h1>
          </div>

          {scene.description && (
            <p class="text-marron/80 text-sm leading-relaxed">{scene.description}</p>
          )}

          <div class="flex flex-col gap-3">
            {scene.capacite && (
              <div class="bg-beige rounded-xl px-5 py-4">
                <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-1">Capacité</p>
                <p class="font-corps text-marron text-sm font-bold">{scene.capacite} places</p>
              </div>
            )}
            {scene.localisation?.latitude !== 0 && scene.localisation?.longitude !== 0 && (
              <div class="bg-beige rounded-xl px-5 py-4">
                <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-1">Localisation</p>
                <a
                  href={`https://www.openstreetmap.org/?mlat=${scene.localisation.latitude}&mlon=${scene.localisation.longitude}&zoom=16`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-corps text-marron text-sm font-bold hover:text-or transition-colors underline">
                  Voir sur la carte
                </a>
              </div>
            )}
          </div>
        </div>

      </div>

      <!-- ARTISTES À L'AFFICHE -->
      {artistes.length > 0 && (
        <section>
          <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-2">Programmation</p>
          <h2 class="font-titre text-2xl text-marron mb-6">Artistes à l'affiche</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {artistes.map((artiste) => {
              const date = artiste.dates_de_representation
                ? new Date(artiste.dates_de_representation).toLocaleDateString('fr-FR', {
                    weekday: 'short', day: 'numeric', month: 'short',
                  })
                : null;
              return (
                <div class="bg-white border-t-2 border-or rounded-2xl p-5 flex items-center justify-between hover:-translate-y-0.5 transition-transform shadow-sm">
                  <div>
                    <a href={`/artistes/${artiste.id}`} class="font-titre font-bold text-marron uppercase text-sm hover:text-or transition-colors">
                      {artiste.nom}
                    </a>
                    {artiste.genre_musical && (
                      <p class="text-marron/50 text-xs font-corps mt-0.5">{artiste.genre_musical}</p>
                    )}
                  </div>
                  {date && <time class="text-or text-sm font-semibold font-corps shrink-0">{date}</time>}
                </div>
              );
            })}
          </div>
        </section>
      )}

    </div>
  </main>
</Layout>
