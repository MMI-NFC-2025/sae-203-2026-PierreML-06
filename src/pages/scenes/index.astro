---
import Layout from '../../layouts/Layout.astro';
import CarteScene from '../../components/CarteScene.astro';
import pb from '../../js/backend.mjs';

let scenes: any[] = [];
let erreur = false;

try {
  scenes = await pb.collection('scenes').getFullList({ sort: 'nom' });
} catch (e) {
  erreur = true;
}
---

<Layout title="Nos Scènes — Festicloze">
  <main class="pt-17.5">
    <section class="max-w-6xl mx-auto px-6 py-12">

      <header class="text-center mb-12">
        <h1 class="font-titre text-4xl text-marron">NOS SCÈNES</h1>
      </header>

      {erreur && (
        <p class="text-center text-marron/60 py-20">Impossible de charger les scènes. Veuillez réessayer plus tard.</p>
      )}

      {!erreur && scenes.length === 0 && (
        <p class="text-center text-marron/60 py-20">Aucune scène pour le moment.</p>
      )}

      {!erreur && scenes.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {scenes.map((scene) => (
            <CarteScene scene={scene} />
          ))}
        </div>
      )}

    </section>
  </main>
</Layout>
