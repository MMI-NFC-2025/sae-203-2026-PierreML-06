---
import Layout from '../../layouts/Layout.astro';
import CarteScene from '../../components/CarteScene.astro';
import pb from '../../js/backend.mjs';

let scenes: any[] = [];
let erreur = false;

try {
  scenes = await pb.collection('scenes').getFullList({ sort: 'nom' });
} catch (e) {
  erreur = true;
}
---

<Layout title="Nos Scènes — Festicloze">
  <main class="pt-17.5">
    <section class="max-w-6xl mx-auto px-6 py-12">

      <header class="mb-12">
        <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-3">Les lieux</p>
        <h1 class="font-titre text-4xl md:text-5xl text-marron leading-none">Nos Scènes</h1>
        <div class="h-px w-12 bg-or mt-4"></div>
      </header>

      {erreur && (
        <p class="text-center text-marron/60 py-20">Impossible de charger les scènes. Veuillez réessayer plus tard.</p>
      )}

      {!erreur && scenes.length === 0 && (
        <p class="text-center text-marron/60 py-20">Aucune scène pour le moment.</p>
      )}

      {!erreur && scenes.length > 0 && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {scenes.map((scene) => (
            <CarteScene scene={scene} />
          ))}
        </div>
      )}

    </section>
  </main>
</Layout>

<script>
  import { initFavBtns } from '../../js/favoris.mjs';
  initFavBtns();
</script>
