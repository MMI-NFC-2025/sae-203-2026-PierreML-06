---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import PbImage from '../../components/PbImage.astro';
import pb from '../../../backend/backend.mjs';
import starEmpty from '../../assets/icons/favorite.svg';
import starFilled from '../../assets/icons/favorite_filled.svg';

const { id } = Astro.params;

let artiste: any = null;
let notFound = false;

try {
  artiste = await pb.collection('artistes').getOne(id as string, { expand: 'scene' });
} catch (e) {
  notFound = true;
}

if (notFound) return Astro.redirect('/404');

const galerie: string[] = artiste.galerie ?? [];
const scene = artiste.expand?.scene;

const date = artiste.dates_de_representation
  ? new Date(artiste.dates_de_representation).toLocaleDateString('fr-FR', {
      weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
    })
  : null;
---

<Layout title={`${artiste.nom} — Festicloze`}>
  <main class="pt-17.5">

    <!-- HERO -->
    <div class="relative h-72 md:h-105 overflow-hidden">
      <PbImage
        record={artiste}
        recordImage={artiste.photo_principale}
        alt={artiste.nom}
        class="w-full h-full object-cover"
        width={1200}
        height={420}
      />
      <div class="absolute inset-0 bg-linear-to-t from-marron/80 via-marron/30 to-transparent"></div>

      <!-- Bouton retour -->
      <a href="/artistes" class="absolute top-6 left-6 inline-flex items-center gap-2 text-white/70 hover:text-white text-xs font-corps font-bold uppercase tracking-widest transition-colors bg-marron/30 backdrop-blur-sm px-4 py-2 rounded-full">
        &larr; Artistes
      </a>

      <!-- Bouton favori -->
      <button
        id="fav-btn-detail"
        class="fav-btn absolute top-6 right-6 w-10 h-10 flex items-center justify-center bg-marron/40 backdrop-blur-sm rounded-full hover:bg-marron/60 transition-colors cursor-pointer border-none"
        data-type="artiste"
        data-id={artiste.id}
        aria-label="Ajouter aux favoris"
        style="display:none">
        <Image src={starEmpty} alt="" width={20} height={20} class="star-empty w-5 h-5" />
        <Image src={starFilled} alt="" width={20} height={20} class="star-filled hidden w-5 h-5" />
      </button>

      <!-- Titre en bas du hero -->
      <div class="absolute bottom-0 left-0 right-0 px-6 pb-8 md:px-10">
        {artiste.genre_musical && (
          <span class="inline-block px-3 py-0.5 bg-or/20 backdrop-blur-sm text-or text-xs uppercase tracking-widest rounded-full mb-3 font-corps font-semibold border border-or/30">
            {artiste.genre_musical}
          </span>
        )}
        <h1 class="font-titre text-3xl md:text-5xl text-white leading-tight">{artiste.nom}</h1>
      </div>
    </div>

    <!-- CONTENU -->
    <div class="max-w-4xl mx-auto px-6 py-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">

        <!-- COLONNE GAUCHE : description -->
        <div class="md:col-span-2 flex flex-col gap-6">
          {artiste.description && (
            <div>
              <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-3">Biographie</p>
              <p class="text-marron/80 text-sm leading-relaxed">{artiste.description}</p>
            </div>
          )}

          <div class="flex flex-wrap gap-3">
            <a
              href="/infos_partique"
              class="inline-block px-8 py-3 bg-rouge text-white font-bold uppercase text-sm tracking-wider rounded-full hover:-translate-y-0.5 transition-transform">
              Réserver le spectacle
            </a>
            <button
              id="fav-text-btn"
              class="inline-block px-8 py-3 border border-or text-or font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:bg-or hover:text-marron transition-colors cursor-pointer"
              style="display:none">
              Ajouter aux favoris
            </button>
          </div>
        </div>

        <!-- COLONNE DROITE : infos pratiques -->
        {(date || scene) && (
          <div class="flex flex-col gap-3">
            {date && (
              <div class="bg-beige rounded-2xl p-5">
                <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-2">Date</p>
                <time class="font-corps text-marron text-sm font-semibold leading-snug">{date}</time>
              </div>
            )}
            {scene && (
              <div class="bg-beige rounded-2xl p-5">
                <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-2">Scène</p>
                <a href={`/scenes/${scene.id}`} class="font-corps text-marron text-sm font-semibold hover:text-or transition-colors">{scene.nom}</a>
              </div>
            )}
          </div>
        )}

      </div>

      <!-- GALERIE -->
      {galerie.length > 0 && (
        <section class="mt-14">
          <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-2">Galerie</p>
          <h2 class="font-titre text-2xl text-marron mb-6">Photos</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {galerie.map((filename: string) => (
              <div class="rounded-2xl overflow-hidden h-48">
                <PbImage
                  record={artiste}
                  recordImage={filename}
                  alt={`${artiste.nom} — galerie`}
                  class="w-full h-48 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                  width={400}
                  height={192}
                />
              </div>
            ))}
          </div>
        </section>
      )}

    </div>
  </main>
</Layout>

<script>
  import { initFavoriDetail } from '../../js/favoriDetail.js';

  initFavoriDetail('artiste');
</script>
