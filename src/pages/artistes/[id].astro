---
import Layout from '../../layouts/Layout.astro';
import PbImage from '../../components/PbImage.astro';
import pb from '../../js/backend.mjs';

const { id } = Astro.params;

let artiste: any = null;
let notFound = false;

try {
  artiste = await pb.collection('artistes').getOne(id as string, {
    expand: 'scene',
  });
} catch (e) {
  notFound = true;
}

if (notFound) {
  return Astro.redirect('/404');
}

const galerie: string[] = artiste.galerie ?? [];
const scene = artiste.expand?.scene;

const date = artiste.dates_de_representation
  ? new Date(artiste.dates_de_representation).toLocaleDateString('fr-FR', {
      weekday: 'long',
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;
---

<Layout title={`${artiste.nom} — Festicloze`}>
  <main class="pt-17.5">
    <div class="max-w-4xl mx-auto px-6 py-12">

      <div class="mb-8">
        <a href="/artistes" class="inline-flex items-center gap-2 text-marron/50 hover:text-or text-xs font-corps font-bold uppercase tracking-widest transition-colors">
          &larr; Nos artistes
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">

        <!-- PHOTO -->
        <div class="w-full rounded-2xl overflow-hidden max-h-96 shadow-lg">
          <PbImage
            record={artiste}
            recordImage={artiste.photo_principale}
            alt={artiste.nom}
            class="w-full max-h-96 object-cover"
            width={600}
            height={384}
          />
        </div>

        <!-- INFOS -->
        <div class="flex flex-col gap-6">
          <div>
            {artiste.genre_musical && (
              <span class="inline-block px-4 py-1 bg-beige text-or text-xs uppercase tracking-widest rounded-full mb-3">
                {artiste.genre_musical}
              </span>
            )}
            <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-2">Ensemble baroque</p>
            <h1 class="font-titre text-[clamp(24px,4vw,40px)] font-bold text-marron leading-tight">{artiste.nom}</h1>
          </div>

          {(date || scene) && (
            <div class="bg-beige rounded-2xl p-5 flex flex-col gap-4">
              {date && (
                <div>
                  <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-1">Date de représentation</p>
                  <time class="font-corps text-marron text-sm font-semibold">{date}</time>
                </div>
              )}
              {scene && (
                <div>
                  <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-1">Scène</p>
                  <a href={`/scenes/${scene.id}`} class="font-corps text-marron text-sm font-semibold hover:text-or transition-colors">{scene.nom}</a>
                </div>
              )}
            </div>
          )}

          {artiste.description && (
            <div>
              <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-2">Biographie</p>
              <h2 class="font-titre text-lg text-marron mb-3 sr-only">Biographie</h2>
              <p class="text-marron/80 text-sm leading-relaxed">{artiste.description}</p>
            </div>
          )}

          <a
            href="/404"
            class="self-start inline-block px-8 py-3 bg-rouge text-white font-bold uppercase text-sm tracking-wider rounded-full hover:-translate-y-0.5 transition-transform">
            Réserver le spectacle
          </a>
        </div>

      </div>

      <!-- GALERIE -->
      {galerie.length > 0 && (
        <section class="mt-14">
          <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-2">Galerie</p>
          <h2 class="font-titre text-2xl text-marron mb-6">Photos</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {galerie.map((filename: string) => (
              <div class="rounded-2xl overflow-hidden h-48">
                <PbImage
                  record={artiste}
                  recordImage={filename}
                  alt={`${artiste.nom} — galerie`}
                  class="w-full h-48 object-cover hover:scale-105 transition-transform duration-500 cursor-zoom-in"
                  width={400}
                  height={192}
                />
              </div>
            ))}
          </div>
        </section>
      )}

    </div>
  </main>
</Layout>
