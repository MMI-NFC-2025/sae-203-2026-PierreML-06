---
import Layout from '../../../layouts/Layout.astro';
import CarteArtiste from '../../../components/CarteArtiste.astro';
import { getArtistesBySceneId, getSceneById } from '../../../js/backend.mjs';

const { id } = Astro.params;

let artistes: any[] = [];
let scene: any = null;
let erreur = false;

try {
  scene = await getSceneById(id as string);
  artistes = await getArtistesBySceneId(id as string);
} catch (e) {
  erreur = true;
}
---

<Layout title={`${scene?.nom ?? 'Scène'} — Artistes — Festicloze`}>
  <main class="pt-17.5">
    <section class="max-w-6xl mx-auto px-6 py-12">

      <div class="mb-8">
        <a href="/artistes" class="inline-flex items-center gap-2 text-marron/50 hover:text-or text-xs font-corps font-bold uppercase tracking-widest transition-colors">
          &larr; Tous les artistes
        </a>
      </div>

      <header class="mb-10">
        <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-3">Filtrage par scène</p>
        <h1 class="font-titre text-4xl md:text-5xl text-marron leading-none">{scene?.nom ?? 'Scène'}</h1>
        <div class="h-px w-12 bg-or mt-4"></div>
      </header>

      {erreur && (
        <p class="text-center text-marron/60 py-20">Impossible de charger les artistes.</p>
      )}

      {!erreur && artistes.length === 0 && (
        <p class="text-center text-marron/60 py-20">Aucun artiste pour cette scène.</p>
      )}

      {!erreur && artistes.length > 0 && (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {artistes.map((artiste) => (
            <CarteArtiste
              artiste={artiste}
              date={artiste.dates_de_representation
                ? new Date(artiste.dates_de_representation).toLocaleDateString('fr-FR', {
                    weekday: 'long', day: 'numeric', month: 'long',
                  })
                : null}
              scene_nom={artiste.expand?.scene?.nom ?? null}
            />
          ))}
        </div>
      )}

    </section>
  </main>
</Layout>
