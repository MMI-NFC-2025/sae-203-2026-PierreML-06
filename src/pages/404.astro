---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page introuvable — Festiclose">
  <main class="pt-17.5 min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-lg mx-auto">

      <p class="font-titre text-[120px] md:text-[180px] leading-none text-beige font-bold select-none">
        404
      </p>

      <h1 class="font-titre text-2xl md:text-3xl text-marron mb-4 -mt-4">
        Page introuvable
      </h1>

      <p class="text-marron/60 text-sm leading-relaxed mb-10 max-w-sm mx-auto">
        La page que vous recherchez n'existe pas ou a été déplacée.
      </p>

      <a
        href="/"
        class="inline-block px-8 py-3 bg-marron text-beige-claire font-bold uppercase text-sm tracking-wider rounded-full hover:-translate-y-0.5 transition-transform">
        Retour à l'accueil
      </a>

    </div>
  </main>
</Layout>

