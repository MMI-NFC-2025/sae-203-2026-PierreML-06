---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/img/hero_acceuil.avif';
import img1 from '../assets/img/image_display4.avif';
import img2 from '../assets/img/image_display3.avif';
import img3 from '../assets/img/image_display2.avif';
import img4 from '../assets/img/image_display1.avif';
---

<Layout title="Festicloze — Accueil">
  <main>

    <!-- HERO -->
    <section class="relative h-screen flex flex-col justify-center items-center overflow-hidden">
      <div class="absolute inset-0">
        <Image
          src={heroImg}
          alt="Ambiance lumineuse et festive du festival"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-marron/55"></div>
      </div>

      <!-- Mobile : colonne centrée / Desktop : 2 colonnes -->
      <div class="relative z-10 w-full max-w-6xl mx-auto px-8 flex flex-col items-center gap-6 md:flex-row md:justify-between md:items-center">

        <!-- Gauche : titre + badge + bouton -->
        <div class="flex flex-col items-center gap-4 md:items-start">
          <div class="flex flex-col items-center gap-3 md:items-start">
            <h1 class="font-titre text-[clamp(40px,8vw,70px)] font-bold text-beige-claire leading-none tracking-widest text-center md:text-left">FESTICLOZE</h1>
            <span class="px-5 py-1.5 bg-beige text-vert font-corps font-bold text-sm rounded-full">
              noël 2025
            </span>
          </div>
          <a href="/404" class="inline-block px-8 py-3 bg-rouge text-white font-bold uppercase text-sm tracking-wider rounded-full hover:-translate-y-0.5 transition-transform shadow-lg">
            Billeterie
          </a>
        </div>

        <!-- Droite : cercle date -->
        <div class="flex items-center justify-center w-64 h-64 md:w-80 md:h-80 bg-vert rounded-full shrink-0">
          <p class="text-white font-corps font-bold text-base md:text-lg text-center leading-relaxed tracking-widest m-0">
            DU 20 au 23 Décembre<br />2025
          </p>
        </div>

      </div>
    </section>

    <!-- PROGRAMMATION CAROUSEL -->
    <section class="py-16 bg-beige-claire">
      <header class="text-center mb-10">
        <h2 class="inline-block px-6 py-2 bg-beige border border-beige rounded-full text-marron font-corps text-sm uppercase tracking-widest font-semibold">
          Programmation
        </h2>
      </header>

      <div class="relative max-w-6xl mx-auto px-10">
        <button
          id="btn-gauche"
          aria-label="Défiler vers la gauche"
          class="hidden md:flex absolute left-0 top-1/2 -translate-y-8 z-10 w-10 h-10 bg-beige-claire border border-beige rounded-full items-center justify-center shadow hover:bg-beige transition-colors cursor-pointer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>

        <div
          id="carrouselProgrammation"
          class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4"
          style="scrollbar-width: none; -ms-overflow-style: none;">

          <article class="snap-start shrink-0 w-70 md:w-[calc(25%-18px)] bg-beige rounded-[20px] overflow-hidden hover:-translate-y-1 transition-transform">
            <h3 class="font-corps text-xs font-semibold uppercase tracking-wider text-marron/60 px-5 pt-5 pb-2">Jour 1 — Samedi 20/12</h3>
            <a href="/artistes" class="block">
              <Image src={img1} alt="Scène de l'opéra L'Orfeo" class="w-full h-48 object-cover" />
              <div class="p-5">
                <p class="font-titre font-bold text-marron uppercase text-base mb-1">L'Orfeo</p>
                <p class="text-marron/80 text-sm font-semibold mb-1">Il Giardino Armonico</p>
                <p class="text-marron/60 text-sm">Aux origines de l'opéra</p>
              </div>
            </a>
          </article>

          <article class="snap-start shrink-0 w-70 md:w-[calc(25%-18px)] bg-beige rounded-[20px] overflow-hidden hover:-translate-y-1 transition-transform">
            <h3 class="font-corps text-xs font-semibold uppercase tracking-wider text-marron/60 px-5 pt-5 pb-2">Jour 2 — Dimanche 21/12</h3>
            <a href="/artistes" class="block">
              <Image src={img2} alt="Spectacle Armide - Les Arts Florissants" class="w-full h-48 object-cover" />
              <div class="p-5">
                <p class="font-titre font-bold text-marron uppercase text-base mb-1">Armide</p>
                <p class="text-marron/80 text-sm font-semibold mb-1">Les Arts Florissants</p>
                <p class="text-marron/60 text-sm">Sous le règne du Roi-Soleil</p>
              </div>
            </a>
          </article>

          <article class="snap-start shrink-0 w-70 md:w-[calc(25%-18px)] bg-beige rounded-[20px] overflow-hidden hover:-translate-y-1 transition-transform">
            <h3 class="font-corps text-xs font-semibold uppercase tracking-wider text-marron/60 px-5 pt-5 pb-2">Jour 3 — Lundi 22/12</h3>
            <a href="/artistes" class="block">
              <Image src={img3} alt="Spectacle Armide - Les Talens Lyriques" class="w-full h-48 object-cover" />
              <div class="p-5">
                <p class="font-titre font-bold text-marron uppercase text-base mb-1">Armide</p>
                <p class="text-marron/80 text-sm font-semibold mb-1">Les Talens Lyriques</p>
                <p class="text-marron/60 text-sm">Passions et virtuosité</p>
              </div>
            </a>
          </article>

          <article class="snap-start shrink-0 w-70 md:w-[calc(25%-18px)] bg-beige rounded-[20px] overflow-hidden hover:-translate-y-1 transition-transform">
            <h3 class="font-corps text-xs font-semibold uppercase tracking-wider text-marron/60 px-5 pt-5 pb-2">Jour 4 — Mardi 23/12</h3>
            <a href="/artistes" class="block">
              <Image src={img4} alt="Grand Final de Noël - Il Seminario Musicale" class="w-full h-48 object-cover" />
              <div class="p-5">
                <p class="font-titre font-bold text-marron uppercase text-base mb-1">Grand Final de Noël</p>
                <p class="text-marron/80 text-sm font-semibold mb-1">Il Seminario Musicale</p>
                <p class="text-marron/60 text-sm">La fête baroque</p>
              </div>
            </a>
          </article>

        </div>

        <button
          id="btn-droite"
          aria-label="Défiler vers la droite"
          class="hidden md:flex absolute right-0 top-1/2 -translate-y-8 z-10 w-10 h-10 bg-beige-claire border border-beige rounded-full items-center justify-center shadow hover:bg-beige transition-colors cursor-pointer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <div class="text-center mt-10">
        <a href="/programmation" class="inline-block px-8 py-3 bg-rouge text-white font-bold uppercase text-sm tracking-wider rounded-full hover:-translate-y-0.5 transition-transform">
          Voir le programme complet
        </a>
      </div>
    </section>

    <!-- INFOS PRATIQUES -->
    <section class="py-16 px-8 bg-beige max-w-4xl mx-auto my-12 rounded-[30px]">
      <h2 class="text-center text-marron font-titre text-3xl mb-4">Infos pratiques</h2>
      <p class="text-center text-marron/80 mb-8 max-w-xl mx-auto text-sm">
        Le Festival Baroque de Noël vous accueille au Temple Saint-Martin de Montbéliard pour sa première édition.
      </p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-xl mx-auto list-none p-0">
        {[
          'Parking gratuit à proximité',
          'Espace vélo',
          'Bar hivernal & douceurs locales',
          'Animations et découverte du baroque',
          'Boutique du festival',
        ].map(item => (
          <li class="flex items-center gap-3 text-marron/80 text-sm">
            <span class="w-2 h-2 rounded-full bg-or shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>
    </section>

    <!-- PARTENAIRES -->
    <section class="py-12 px-4 text-center max-w-4xl mx-auto">
      <h2 class="font-titre text-3xl text-marron mb-8">Nos Partenaires</h2>
      <ul class="flex flex-wrap justify-center gap-x-8 gap-y-3 list-none p-0">
        {[
          'Ville de Montbéliard',
          'Pays de Montbéliard Agglomération',
          'Région Bourgogne-Franche-Comté',
          'MA Scène Nationale',
          'Conservatoire du Pays de Montbéliard',
          'France Bleu Belfort-Montbéliard',
          "L'Est Républicain",
          'Crédit Mutuel',
        ].map(p => (
          <li class="text-marron/70 text-sm font-semibold">{p}</li>
        ))}
      </ul>
    </section>

  </main>
</Layout>

<script>
  import '../js/carousel.js';
</script>
