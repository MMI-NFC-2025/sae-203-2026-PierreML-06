---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import PbImage from '../components/PbImage.astro';
import heroImg from '../assets/img/hero_acceuil.avif';
import logoCreditMutuel from '../assets/img/Partenaire1.avif';
import logoCocaCola from '../assets/img/Partenaire2.avif';
import logoDeezer from '../assets/img/Partenaire3.avif';
import logoNrj from '../assets/img/Partenaire4.avif';
import logoWeezevent from '../assets/img/Partenaire5.avif';
import logoDesperados from '../assets/img/Partenaire6.avif';
import { getArtistesByDate } from '../../backend/backend.mjs';

let artistes: any[] = [];
try {
  artistes = await getArtistesByDate();
} catch (_) {}

const practicalItems = [
  { label: 'Parking gratuit', detail: 'Accès fléché depuis les entrées de ville' },
  { label: 'Espace vélo', detail: 'Parc sécurisé + réparations d\'urgence' },
  { label: 'Bar hivernal', detail: 'Vin chaud & douceurs locales' },
  { label: 'Boutique', detail: 'Souvenirs et éditions du festival' },
  { label: 'Restauration', detail: 'Restaurateurs partenaires sur place' },
  { label: 'Accessibilité', detail: 'Site accessible aux personnes à mobilité réduite' },
];

const partnerLogos = [
  { src: logoCreditMutuel, alt: 'Crédit Mutuel' },
  { src: logoCocaCola, alt: 'Coca-Cola' },
  { src: logoDeezer, alt: 'Deezer' },
  { src: logoNrj, alt: 'NRJ' },
  { src: logoWeezevent, alt: 'Weezevent' },
  { src: logoDesperados, alt: 'Desperados' },
];

const institutionalPartners = [
  'Ville de Montbéliard',
  'Pays de Montbéliard Agglomération',
  'Région Bourgogne-Franche-Comté',
  'MA Scène Nationale',
  'Conservatoire du Pays de Montbéliard',
  'France Bleu Belfort-Montbéliard',
  'L\'Est Républicain',
];
---

<Layout title="Festicloze - Accueil">
  <main>
    <section class="relative h-screen flex flex-col justify-center items-center overflow-hidden">
      <div class="absolute inset-0">
        <Image
          src={heroImg}
          alt="Ambiance lumineuse et festive du festival baroque de Noël"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-marron/60"></div>
      </div>

      <div class="relative z-10 w-full max-w-6xl mx-auto px-8 flex flex-col items-center gap-8 md:flex-row md:justify-between md:items-center">
        <div class="flex flex-col items-center gap-5 md:items-start">
          <div class="flex flex-col items-center gap-3 md:items-start">
            <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-1">Festival Baroque de Noël</p>
            <h1 class="font-titre text-[clamp(44px,8vw,72px)] font-normal leading-none tracking-widest text-center md:text-left" style="color:#ffffff">FESTICLOSE</h1>
            <div class="h-px w-16 bg-or"></div>
            <span class="px-5 py-1.5 bg-beige text-vert font-corps font-bold text-xs tracking-widest rounded-full uppercase">
              Noël 2025
            </span>
          </div>
          <p class="text-beige-claire/70 text-sm text-center md:text-left font-corps hidden md:block max-w-xs leading-relaxed">
            Quatre soirées d'opéra baroque au Temple Saint-Martin de Montbéliard.
          </p>
          <a href="/infos_partique" class="inline-block px-8 py-3 bg-rouge text-white font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:-translate-y-0.5 transition-transform shadow-lg">
            Billetterie
          </a>
        </div>

        <div class="flex flex-col items-center justify-center w-64 h-64 md:w-80 md:h-80 bg-vert rounded-full shrink-0 gap-2">
          <p class="text-white/60 font-corps text-xs uppercase tracking-widest">Dates</p>
          <p class="text-white font-corps font-bold text-base md:text-lg text-center leading-snug tracking-wider m-0">
            DU 20 AU 23<br />DÉCEMBRE 2025
          </p>
          <div class="h-px w-8 bg-white/40 my-1"></div>
          <p class="text-white/70 font-corps text-xs text-center tracking-wide">Montbéliard</p>
        </div>
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10">
        <span class="text-beige-claire/50 font-corps text-xs uppercase tracking-widest">Découvrir</span>
        <div class="w-px h-8 bg-beige-claire/30 animate-pulse"></div>
      </div>
    </section>

    <section class="bg-marron py-20 px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-6">Temple Saint-Martin, Montbéliard</p>
        <blockquote class="font-titre text-2xl md:text-3xl text-beige-claire leading-relaxed mb-8 font-normal">
          "Une rencontre unique entre l'excellence baroque, le patrimoine historique et la magie de Noël."
        </blockquote>
        <div class="h-px w-12 bg-or mx-auto mb-8"></div>
        <p class="text-beige-claire/60 font-corps text-sm leading-relaxed max-w-xl mx-auto mb-10">
          Festiclose réunit chaque décembre les plus grands ensembles baroques européens dans le cadre exceptionnel
          du Temple Saint-Martin. Quatre soirées, quatre univers musicaux, une seule ambiance.
        </p>
        <a href="/festival" class="inline-block px-8 py-3 border border-or text-or font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:bg-or hover:text-marron transition-colors">
          L'esprit du festival
        </a>
      </div>
    </section>

    <section class="py-20 bg-beige-claire">
      <div class="max-w-6xl mx-auto px-6 mb-12">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
          <div>
            <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-2">Programme</p>
            <h2 class="font-titre text-3xl md:text-4xl text-marron leading-none">La Programmation</h2>
          </div>
          <a href="/programmation" class="font-corps text-xs font-bold text-marron/50 uppercase tracking-widest hover:text-or transition-colors self-start sm:self-auto">
            Voir tout &rarr;
          </a>
        </div>
      </div>

      <div class="relative max-w-6xl mx-auto px-10">
        <button
          id="btn-gauche"
          aria-label="Défiler vers la gauche"
          class="hidden md:flex absolute left-0 top-1/2 -translate-y-10 z-10 w-10 h-10 bg-beige-claire border border-beige rounded-full items-center justify-center shadow hover:bg-beige transition-colors cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>

        <div
          id="carrouselProgrammation"
          class="flex gap-5 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4"
          style="scrollbar-width: none; -ms-overflow-style: none;">

          {artistes.map((artiste: any) => {
            const dateLabel = artiste.dates_de_representation
              ? new Date(artiste.dates_de_representation).toLocaleDateString('fr-FR', {
                  weekday: 'short', day: 'numeric', month: 'short',
                })
              : null;
            return (
              <article class="group snap-start shrink-0 w-72 md:w-[calc(25%-15px)] bg-white rounded-2xl overflow-hidden hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md border-t-2 border-or">
                <a href={`/artistes/${artiste.id}`} class="block">
                  <div class="relative overflow-hidden h-48">
                    <PbImage
                      record={artiste}
                      recordImage={artiste.photo_principale}
                      alt={artiste.nom}
                      class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500"
                      width={400}
                      height={192}
                    />
                    <div class="absolute inset-0 bg-linear-to-t from-marron/60 to-transparent"></div>
                    {dateLabel && (
                      <div class="absolute bottom-3 left-4">
                        <p class="font-corps text-white text-xs font-bold">{dateLabel}</p>
                      </div>
                    )}
                  </div>
                  <div class="p-5">
                    <p class="font-titre font-bold text-marron uppercase text-sm mb-1 leading-tight">{artiste.nom}</p>
                    {artiste.genre_musical && (
                      <p class="text-or text-xs font-corps font-semibold mb-2">{artiste.genre_musical}</p>
                    )}
                    {artiste.expand?.scene?.nom && (
                      <p class="text-marron/50 text-xs font-corps italic">{artiste.expand.scene.nom}</p>
                    )}
                  </div>
                </a>
              </article>
            );
          })}

        </div>

        <button
          id="btn-droite"
          aria-label="Défiler vers la droite"
          class="hidden md:flex absolute right-0 top-1/2 -translate-y-10 z-10 w-10 h-10 bg-beige-claire border border-beige rounded-full items-center justify-center shadow hover:bg-beige transition-colors cursor-pointer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <div class="text-center mt-12">
        <a href="/programmation" class="inline-block px-8 py-3 bg-marron text-beige-claire font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:-translate-y-0.5 transition-transform">
          Programme complet
        </a>
      </div>
    </section>

    <section class="py-16 px-6 bg-beige">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">

        <a href="/artistes" class="group relative overflow-hidden rounded-2xl bg-marron px-8 py-10 flex flex-col gap-3 hover:-translate-y-0.5 transition-transform">
          <p class="font-corps text-or text-xs uppercase tracking-[4px]">À l'affiche</p>
          <h3 class="font-titre text-2xl text-beige-claire leading-tight">Nos Artistes</h3>
          <p class="text-beige-claire/60 text-sm font-corps leading-relaxed">
            Les plus grands ensembles baroques européens réunis pour quatre soirées d'exception.
          </p>
          <span class="font-corps text-or text-xs font-bold uppercase tracking-widest group-hover:translate-x-1 transition-transform inline-block mt-2">
            Découvrir &rarr;
          </span>
        </a>

        <a href="/scenes" class="group relative overflow-hidden rounded-2xl bg-beige-claire px-8 py-10 flex flex-col gap-3 hover:-translate-y-0.5 transition-transform border border-beige">
          <p class="font-corps text-or text-xs uppercase tracking-[4px]">Les lieux</p>
          <h3 class="font-titre text-2xl text-marron leading-tight">Nos Scènes</h3>
          <p class="text-marron/60 text-sm font-corps leading-relaxed">
            Des lieux chargés d'histoire au cœur de Montbéliard pour des concerts d'une acoustique remarquable.
          </p>
          <span class="font-corps text-marron text-xs font-bold uppercase tracking-widest group-hover:translate-x-1 transition-transform inline-block mt-2">
            Découvrir &rarr;
          </span>
        </a>

      </div>
    </section>

    <section class="py-20 px-6 bg-beige-claire">
      <div class="max-w-6xl mx-auto">
        <div class="md:grid md:grid-cols-2 md:gap-16 md:items-center">

          <div class="mb-10 md:mb-0">
            <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-3">Sur place</p>
            <h2 class="font-titre text-3xl md:text-4xl text-marron mb-4 leading-tight">Infos pratiques</h2>
            <p class="text-marron/60 text-sm font-corps leading-relaxed mb-6">
              Le Festival Baroque de Noël vous accueille au Temple Saint-Martin de Montbéliard
              pour sa première édition. Tout est prévu pour votre confort.
            </p>
            <a href="/infos_partique" class="inline-block px-8 py-3 border border-marron text-marron font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:bg-marron hover:text-beige-claire transition-colors">
              En savoir plus
            </a>
          </div>

          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 list-none p-0">
            {practicalItems.map((item) => (
              <li class="bg-beige rounded-xl px-4 py-3 flex flex-col gap-1">
                <span class="font-corps font-bold text-marron text-xs uppercase tracking-wide flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-or shrink-0"></span>
                  {item.label}
                </span>
                <span class="text-marron/50 text-xs font-corps">{item.detail}</span>
              </li>
            ))}
          </ul>

        </div>
      </div>
    </section>

    <section class="py-16 px-6 bg-beige">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-10">
          <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-3">Ils nous soutiennent</p>
          <h2 class="font-titre text-2xl md:text-3xl text-marron">Nos Partenaires</h2>
          <div class="h-px w-12 bg-or mx-auto mt-4"></div>
        </div>

        <div class="flex flex-wrap justify-center items-center gap-6 mb-10">
          {partnerLogos.map((logo) => (
            <div class="bg-marron rounded-2xl px-5 py-4 flex items-center justify-center h-24 w-44 shadow-sm border border-marron/10">
              <Image src={logo.src} alt={logo.alt} width={140} height={60} class="max-h-12 w-auto max-w-[82%] object-contain" />
            </div>
          ))}
        </div>

        <div class="h-px w-full bg-beige-claire mb-8"></div>
        <p class="text-center font-corps text-marron/40 text-xs uppercase tracking-widest mb-5">Soutiens institutionnels</p>
        <ul class="flex flex-wrap justify-center gap-3 list-none p-0">
          {institutionalPartners.map((partner) => (
            <li class="px-4 py-2 bg-beige-claire border border-beige rounded-full text-marron/70 text-xs font-corps font-semibold tracking-wide">
              {partner}
            </li>
          ))}
        </ul>
      </div>
    </section>

  </main>
</Layout>

<script>
  import '../js/carousel.js';
</script>
