---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Connexion — Festiclose">
  <main class="pt-17.5 min-h-screen flex items-center justify-center bg-beige-claire px-6 py-12">
    <div class="w-full max-w-md">

      <div class="text-center mb-10">
        <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-3">Espace réservé</p>
        <h1 class="font-titre text-4xl text-marron leading-none mb-2">Connexion</h1>
        <div class="h-px w-12 bg-or mx-auto mb-4"></div>
        <p class="text-marron/50 font-corps text-sm">Connectez-vous à votre compte festivalier.</p>
      </div>

      <form id="form-login" class="bg-beige rounded-2xl p-8 flex flex-col gap-5">

        <div class="flex flex-col gap-1.5">
          <label for="email" class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Adresse e-mail</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors"
          />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="password" class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Mot de passe</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="current-password"
            class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors"
          />
        </div>

        <div id="retour-login" class="hidden text-sm font-corps px-4 py-3 rounded-xl"></div>

        <button
          type="submit"
          id="btn-login"
          class="px-8 py-3 bg-marron text-beige-claire font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:-translate-y-0.5 transition-transform cursor-pointer">
          Se connecter
        </button>

      </form>

      <p class="text-center font-corps text-sm text-marron/50 mt-6">
        Pas encore de compte ?
        <a href="/inscription" class="text-or font-bold hover:underline">Créer un compte</a>
      </p>

    </div>
  </main>
</Layout>

<script>
  import pb from '../../backend/backend.mjs';

  const form = document.getElementById('form-login') as HTMLFormElement;
  const retour = document.getElementById('retour-login') as HTMLElement;
  const btn = document.getElementById('btn-login') as HTMLButtonElement;

  function showRetour(ok: boolean, msg: string) {
    retour.textContent = msg;
    retour.className = `text-sm font-corps px-4 py-3 rounded-xl ${ok ? 'bg-vert/10 text-vert' : 'bg-rouge/10 text-rouge'}`;
    retour.classList.remove('hidden');
  }

  // Rediriger si déjà connecté
  if (pb.authStore.isValid) {
    window.location.href = '/profil';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const email = fd.get('email') as string;
    const password = fd.get('password') as string;

    btn.disabled = true;
    btn.textContent = 'Connexion...';

    try {
      await pb.collection('users').authWithPassword(email, password);
      showRetour(true, 'Connexion réussie. Redirection...');
      setTimeout(() => {
        window.location.href = '/profil';
      }, 800);
    } catch (err: any) {
      showRetour(false, 'Identifiants incorrects. Veuillez réessayer.');
      btn.disabled = false;
      btn.textContent = 'Se connecter';
    }
  });
</script>

