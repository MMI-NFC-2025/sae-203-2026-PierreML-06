---
import Layout from '../layouts/Layout.astro';
import { getArtistesByDate, getScenesByNom } from '../../backend/backend.mjs';

// Protection basique : rediriger si non connecté (géré côté client via JS)
let artistes: any[] = [];
let scenes: any[] = [];

try {
  artistes = await getArtistesByDate();
  scenes = await getScenesByNom();
} catch (_) {}

const artistGenres = [
  'classique',
  'jazz',
  'gospel',
  'baroque',
  'opera_baroque',
  'musique_sacree',
  'danse_baroque',
  'ensemble_vocal',
  'musique_de_chambre',
];

const modeParam = Astro.url.searchParams.get('mode') ?? 'artiste';
const idParam = Astro.url.searchParams.get('id') ?? '';

// Pré-remplissage si modification
const artisteEdite = idParam ? artistes.find(a => a.id === idParam) : null;
const sceneEditee = idParam ? scenes.find(s => s.id === idParam) : null;
---

<Layout title="Administration — Festicloze">
  <main class="pt-17.5">
    <div class="max-w-5xl mx-auto px-6 py-12">

      <header class="mb-10">
        <p class="font-corps text-or text-xs uppercase tracking-[4px] mb-3">Backoffice</p>
        <h1 class="font-titre text-4xl text-marron leading-none mb-2">Administration</h1>
        <div class="h-px w-12 bg-or mb-6"></div>
        <p class="text-marron/50 font-corps text-sm">Gérer les artistes et les scènes du festival.</p>
      </header>

      <!-- ONGLETS -->
      <div class="flex gap-3 mb-10">
        <a
          href="/admin?mode=artiste"
          class={`px-5 py-2 rounded-full text-xs font-corps font-bold uppercase tracking-widest border transition-colors ${modeParam === 'artiste' ? 'bg-marron text-beige-claire border-marron' : 'border-beige text-marron hover:border-marron'}`}>
          Artistes
        </a>
        <a
          href="/admin?mode=scene"
          class={`px-5 py-2 rounded-full text-xs font-corps font-bold uppercase tracking-widest border transition-colors ${modeParam === 'scene' ? 'bg-marron text-beige-claire border-marron' : 'border-beige text-marron hover:border-marron'}`}>
          Scènes
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

        <!-- FORMULAIRE -->
        <div>
          {modeParam === 'artiste' && (
            <form id="form-artiste" class="bg-beige rounded-2xl p-8 flex flex-col gap-5">
              <h2 class="font-titre text-xl text-marron mb-2">
                {artisteEdite ? `Modifier : ${artisteEdite.nom}` : 'Ajouter un artiste'}
              </h2>
              <input type="hidden" name="id" value={artisteEdite?.id ?? ''} />

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Nom</label>
                <input type="text" name="nom" required value={artisteEdite?.nom ?? ''}
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors" />
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Genre musical</label>
                <select name="genre_musical"
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors">
                  <option value="">— Sélectionner un genre —</option>
                  {artistGenres.map(genre => (
                    <option value={genre} selected={artisteEdite?.genre_musical === genre}>{genre}</option>
                  ))}
                </select>
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Description</label>
                <textarea name="description" rows="4"
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors resize-none">{artisteEdite?.description ?? ''}</textarea>
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Photo principale</label>
                {artisteEdite?.photo_principale && (
                  <img
                    src={`https://pbsae203.pierre-mouilleseaux-lhuillier.fr/api/files/artistes/${artisteEdite.id}/${artisteEdite.photo_principale}`}
                    alt="Photo actuelle"
                    class="w-full h-32 object-cover rounded-xl mb-2"
                  />
                )}
                <input type="file" name="photo_principale" accept="image/*"
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors file:mr-3 file:py-1 file:px-3 file:rounded-full file:border-0 file:text-xs file:font-corps file:font-bold file:uppercase file:bg-marron file:text-beige-claire cursor-pointer" />
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Date de représentation</label>
                <input type="datetime-local" name="dates_de_representation"
                  value={artisteEdite?.dates_de_representation ? artisteEdite.dates_de_representation.substring(0, 16) : ''}
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors" />
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Scène</label>
                <select name="scene"
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors">
                  <option value="">— Aucune scène —</option>
                  {scenes.map(s => (
                    <option value={s.id} selected={artisteEdite?.scene === s.id}>{s.nom}</option>
                  ))}
                </select>
              </div>

              <div id="retour-artiste" class="hidden text-sm font-corps px-4 py-3 rounded-xl"></div>

              <div class="flex flex-wrap gap-3">
                <button type="submit"
                  class="w-full sm:w-auto px-8 py-3 bg-vert text-white font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:-translate-y-0.5 transition-transform cursor-pointer">
                  {artisteEdite ? 'Enregistrer' : 'Ajouter'}
                </button>
                {artisteEdite && (
                  <button
                    type="button"
                    id="btn-supprimer-artiste"
                    class="w-full sm:w-auto px-6 py-3 bg-rouge text-white font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:-translate-y-0.5 transition-transform cursor-pointer">
                    Supprimer
                  </button>
                )}
                {artisteEdite && (
                  <a href="/admin?mode=artiste"
                    class="w-full sm:w-auto text-center px-6 py-3 border border-beige text-marron font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:border-marron transition-colors">
                    Annuler
                  </a>
                )}
              </div>
            </form>
          )}

          {modeParam === 'scene' && (
            <form id="form-scene" class="bg-beige rounded-2xl p-8 flex flex-col gap-5">
              <h2 class="font-titre text-xl text-marron mb-2">
                {sceneEditee ? `Modifier : ${sceneEditee.nom}` : 'Ajouter une scène'}
              </h2>
              <input type="hidden" name="id" value={sceneEditee?.id ?? ''} />

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Nom</label>
                <input type="text" name="nom" required value={sceneEditee?.nom ?? ''}
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors" />
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Description</label>
                <textarea name="description" rows="4"
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors resize-none">{sceneEditee?.description ?? ''}</textarea>
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Capacité</label>
                <input type="number" name="capacite" value={sceneEditee?.capacite ?? ''}
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors" />
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Adresse</label>
                <input type="text" name="adresse" value={sceneEditee?.adresse ?? ''}
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors" />
              </div>

              <div class="flex flex-col gap-1.5">
                <label class="font-corps text-xs font-bold text-marron/60 uppercase tracking-widest">Photo</label>
                {sceneEditee?.photo && (
                  <img
                    src={`https://pbsae203.pierre-mouilleseaux-lhuillier.fr/api/files/scenes/${sceneEditee.id}/${sceneEditee.photo}`}
                    alt="Photo actuelle"
                    class="w-full h-32 object-cover rounded-xl mb-2"
                  />
                )}
                <input type="file" name="photo" accept="image/*"
                  class="bg-beige-claire rounded-xl px-4 py-3 text-marron text-sm border-b-2 border-beige focus:border-or outline-none transition-colors file:mr-3 file:py-1 file:px-3 file:rounded-full file:border-0 file:text-xs file:font-corps file:font-bold file:uppercase file:bg-marron file:text-beige-claire cursor-pointer" />
              </div>

              <div id="retour-scene" class="hidden text-sm font-corps px-4 py-3 rounded-xl"></div>

              <div class="flex flex-wrap gap-3">
                <button type="submit"
                  class="w-full sm:w-auto px-8 py-3 bg-vert text-white font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:-translate-y-0.5 transition-transform cursor-pointer">
                  {sceneEditee ? 'Enregistrer' : 'Ajouter'}
                </button>
                {sceneEditee && (
                  <button
                    type="button"
                    id="btn-supprimer-scene"
                    class="w-full sm:w-auto px-6 py-3 bg-rouge text-white font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:-translate-y-0.5 transition-transform cursor-pointer">
                    Supprimer
                  </button>
                )}
                {sceneEditee && (
                  <a href="/admin?mode=scene"
                    class="w-full sm:w-auto text-center px-6 py-3 border border-beige text-marron font-corps font-bold uppercase text-xs tracking-widest rounded-full hover:border-marron transition-colors">
                    Annuler
                  </a>
                )}
              </div>
            </form>
          )}
        </div>

        <!-- LISTE EXISTANTS -->
        <div>
          {modeParam === 'artiste' && (
            <div>
              <h2 class="font-corps font-bold text-marron text-xs uppercase tracking-widest mb-4">
                Artistes existants ({artistes.length})
              </h2>
              <ul class="flex flex-col gap-2 max-h-150 overflow-y-auto pr-1">
                {artistes.map(a => (
                  <li class="bg-white rounded-xl px-4 py-3 flex items-center justify-between gap-3 border-l-2 border-or shadow-sm">
                    <div>
                      <p class="font-corps font-bold text-marron text-sm">{a.nom}</p>
                      {a.genre_musical && <p class="text-or text-xs font-corps">{a.genre_musical}</p>}
                    </div>
                    <a href={`/admin?mode=artiste&id=${a.id}`}
                      class="text-marron/40 hover:text-or text-xs font-corps font-bold uppercase tracking-widest transition-colors shrink-0">
                      Modifier
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {modeParam === 'scene' && (
            <div>
              <h2 class="font-corps font-bold text-marron text-xs uppercase tracking-widest mb-4">
                Scènes existantes ({scenes.length})
              </h2>
              <ul class="flex flex-col gap-2">
                {scenes.map(s => (
                  <li class="bg-white rounded-xl px-4 py-3 flex items-center justify-between gap-3 border-l-2 border-or shadow-sm">
                    <div>
                      <p class="font-corps font-bold text-marron text-sm">{s.nom}</p>
                      {s.capacite && <p class="text-or text-xs font-corps">{s.capacite} places</p>}
                    </div>
                    <a href={`/admin?mode=scene&id=${s.id}`}
                      class="text-marron/40 hover:text-or text-xs font-corps font-bold uppercase tracking-widest transition-colors shrink-0">
                      Modifier
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

      </div>
    </div>
  </main>
</Layout>

<script>
  import pb from '../../backend/backend.mjs';

  // Protection : réservé aux admins
  if (!pb.authStore.isValid || !pb.authStore.record?.['admin']) {
    window.location.href = '/';
  }

  function showRetour(el: HTMLElement, ok: boolean, msg: string) {
    el.textContent = msg;
    el.className = `text-sm font-corps px-4 py-3 rounded-xl ${ok ? 'bg-vert/10 text-vert' : 'bg-rouge/10 text-rouge'}`;
    el.classList.remove('hidden');
  }

  const formArtiste = document.getElementById('form-artiste') as HTMLFormElement | null;
  if (formArtiste) {
    formArtiste.addEventListener('submit', async (e) => {
      e.preventDefault();
      const raw = new FormData(formArtiste);
      const retour = document.getElementById('retour-artiste') as HTMLElement;
      try {
        const id = (raw.get('id') as string) || '';
        const fd = new FormData();
        fd.append('nom', raw.get('nom') as string);
        fd.append('genre_musical', raw.get('genre_musical') as string);
        fd.append('description', raw.get('description') as string);
        const dateVal = raw.get('dates_de_representation') as string;
        if (dateVal) fd.append('dates_de_representation', dateVal);
        const sceneVal = raw.get('scene') as string;
        if (sceneVal) fd.append('scene', sceneVal);
        const file = raw.get('photo_principale') as File;
        if (file && file.size > 0) fd.append('photo_principale', file);
        if (id) {
          await pb.collection('artistes').update(id, fd);
          showRetour(retour, true, 'Artiste mis à jour.');
        } else {
          await pb.collection('artistes').create(fd);
          showRetour(retour, true, 'Artiste ajouté.');
          formArtiste.reset();
        }
      } catch (err: any) {
        showRetour(retour, false, 'Erreur : ' + (err.message ?? 'inconnue'));
      }
    });
  }

  document.getElementById('btn-supprimer-artiste')?.addEventListener('click', async () => {
    const id = (formArtiste?.querySelector('input[name="id"]') as HTMLInputElement | null)?.value || '';
    const retour = document.getElementById('retour-artiste') as HTMLElement | null;
    if (!id) return;
    if (!window.confirm('Supprimer cet artiste ?')) return;

    try {
      await pb.collection('artistes').delete(id);
      window.location.href = '/admin?mode=artiste';
    } catch (err: any) {
      if (retour) showRetour(retour, false, 'Erreur : ' + (err.message ?? 'inconnue'));
    }
  });

  const formScene = document.getElementById('form-scene') as HTMLFormElement | null;
  if (formScene) {
    formScene.addEventListener('submit', async (e) => {
      e.preventDefault();
      const raw = new FormData(formScene);
      const retour = document.getElementById('retour-scene') as HTMLElement;
      try {
        const id = (raw.get('id') as string) || '';
        const fd = new FormData();
        fd.append('nom', raw.get('nom') as string);
        fd.append('description', raw.get('description') as string);
        const capaciteVal = raw.get('capacite') as string;
        if (capaciteVal) fd.append('capacite', capaciteVal);
        fd.append('adresse', raw.get('adresse') as string);
        const file = raw.get('photo') as File;
        if (file && file.size > 0) fd.append('photo', file);
        if (id) {
          await pb.collection('scenes').update(id, fd);
          showRetour(retour, true, 'Scène mise à jour.');
        } else {
          await pb.collection('scenes').create(fd);
          showRetour(retour, true, 'Scène ajoutée.');
          formScene.reset();
        }
      } catch (err: any) {
        showRetour(retour, false, 'Erreur : ' + (err.message ?? 'inconnue'));
      }
    });
  }

  document.getElementById('btn-supprimer-scene')?.addEventListener('click', async () => {
    const id = (formScene?.querySelector('input[name="id"]') as HTMLInputElement | null)?.value || '';
    const retour = document.getElementById('retour-scene') as HTMLElement | null;
    if (!id) return;
    if (!window.confirm('Supprimer cette scène ?')) return;

    try {
      await pb.collection('scenes').delete(id);
      window.location.href = '/admin?mode=scene';
    } catch (err: any) {
      if (retour) showRetour(retour, false, 'Erreur : ' + (err.message ?? 'inconnue'));
    }
  });
</script>
